# Copy to `.env` (development) or `.env.production` (production).
# Never commit real secrets. Only this file is versioned.

# =============================================================================
# Development (local Postgres)
# =============================================================================

ENV=development
APP_URL=http://localhost:8000
PORT=8000

# PostgreSQL (async via asyncpg). `postgresql://` vira `postgresql+asyncpg://`.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ciatec_research_api_v2_db

# Optional: dedicated DB for pytest (recommended). If unset, tests use DATABASE_URL.
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ciatec_research_api_v2_test

# Comma-separated browser origins for CORS.
CORS_ORIGINS=http://localhost:3000,http://localhost:3333

DATABASE_ECHO=false

# --- Auth ---
JWT_SECRET=change-me-access-token-secret-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-pepper-min-16-chars
# Lifetimes: plain seconds (`900`) or suffix `s`/`m`/`h`/`d` (e.g. `30m`, `7d`).
JWT_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800
# JWT_ISSUER=https://api.example.com
# JWT_AUDIENCE=ciatec-research-api

# Legacy (still supported): minutes / days instead of the two vars above.
# JWT_ACCESS_EXPIRE_MINUTES=15
# JWT_REFRESH_EXPIRE_DAYS=7

# =============================================================================
# Production (EC2 + RDS) — required variables
# =============================================================================
#
# ENV=production
# APP_URL=https://api.ciatec.org
# PORT=8000
#
# DATABASE_URL=postgresql://USER:PASSWORD@your-rds-host:5432/your_db?sslmode=require
#
# CORS_ORIGINS=https://app.ciatec.org,https://admin.ciatec.org
#
# JWT_SECRET=<min 16 chars, unique, secret>
# JWT_REFRESH_SECRET=<min 16 chars, unique, secret>
# JWT_EXPIRES_IN=30m
# JWT_REFRESH_EXPIRES_IN=7d
# JWT_ISSUER=ciatec-research-api
# JWT_AUDIENCE=ciatec-research-api-users
#
# DATABASE_ECHO=false
#
# --- Optional (defaults are fine without Redis on a single EC2) ---
# REDIS_URL=redis://host:6379/0
# TIMELINE_CACHE_ENABLED=true
# TIMELINE_CACHE_TTL_SECONDS=120
# TIMELINE_EVENTS_ASYNC=false
# PROJECT_EXPORT_ASYNC_MIN_ROWS=5000
# PROJECT_EXPORT_BATCH_SIZE=500
# PROJECT_EXPORT_STORAGE_DIR=/var/lib/ciatec/exports
# SELF_REPORT_TOKEN_TTL_SECONDS=259200
#
# Do not use (Node legacy, ignored by the Python API):
# NODE_ENV, schema=public
