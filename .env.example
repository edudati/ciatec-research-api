# Copie para .env e ajuste os valores. Nunca commite o .env.
# Ver docs/DOT-ENV-GUIDE.md para detalhes.

NODE_ENV=development

# URL pública/base da API (deve refletir PORT em localhost)
APP_URL=http://localhost:3333
PORT=3333

# PostgreSQL (ex.: Docker compose na máquina host — ver docs/COMO-RODAR-LOCAL.md)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ciatec_research

# JWT — use segredos longos e aleatórios em produção
JWT_SECRET=change-me-access-secret-min-32-chars-long
JWT_EXPIRES_IN=30m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=ciatec-research-api
JWT_AUDIENCE=ciatec-research-clients
