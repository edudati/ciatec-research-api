generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  RESEARCHER
  PLAYER
}

model User {
  id        String     @id @default(uuid())
  name      String
  role      UserRole   @default(PLAYER)
  authUser  AuthUser?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  userGames               UserGame[]
  sessions                Session[]
  userLevelProgress   UserLevelProgress[]

  @@map("users")
}

model AuthUser {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("auth_users")
}

model RefreshToken {
  id         String    @id @default(uuid())
  token      String    @unique
  authUserId String
  authUser   AuthUser  @relation(fields: [authUserId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@map("refresh_tokens")
}

model Game {
  id          String     @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime   @default(now())
  presets     Preset[]
  userGames   UserGame[]
  matches     Match[]

  @@map("games")
}

model Preset {
  id          String     @id @default(uuid())
  gameId      String
  game        Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isDefault   Boolean    @default(false)
  levels      Level[]
  userGames   UserGame[]

  @@index([gameId])
  @@index([gameId, isDefault])
  @@map("presets")
}

model Level {
  id                 String     @id @default(uuid())
  presetId            String
  preset              Preset     @relation(fields: [presetId], references: [id], onDelete: Cascade)
  name                String
  order                Int        @map("order")
  config              Json
  userGames            UserGame[]        @relation("CurrentLevel")
  matches             Match[]
  userLevelProgress   UserLevelProgress[]

  @@index([presetId])
  @@unique([presetId, order])
  @@map("levels")
}

model UserGame {
  id             String   @id @default(uuid())
  userId         String
  gameId         String
  presetId       String
  currentLevelId String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game           Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  preset         Preset   @relation(fields: [presetId], references: [id], onDelete: Cascade)
  currentLevel   Level    @relation("CurrentLevel", fields: [currentLevelId], references: [id], onDelete: Restrict)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([gameId])
  @@index([presetId])
  @@index([currentLevelId])
  @@unique([userId, gameId])
  @@map("user_games")
}

/// Per (user, level) progress, bests, and lock state. Missing row means locked / not started for that level
/// in API responses; first level in preset is auto-seeded as unlocked in progress start / match start.
model UserLevelProgress {
  id        String   @id @default(uuid())
  userId    String
  levelId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  level     Level    @relation(fields: [levelId], references: [id], onDelete: Cascade)
  unlocked  Boolean  @default(false)
  completed Boolean  @default(false)
  bests     Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, levelId])
  @@index([userId])
  @@index([levelId])
  @@map("user_level_progress")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionDate DateTime @map("session_date") @db.Date
  startedAt DateTime @default(now())
  matches   Match[]

  @@index([userId])
  @@unique([userId, sessionDate])
  @@map("sessions")
}

model Match {
  id                  String   @id @default(uuid())
  sessionId           String
  gameId              String
  levelId             String
  session             Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  game                Game     @relation(fields: [gameId], references: [id], onDelete: Restrict)
  level               Level    @relation(fields: [levelId], references: [id], onDelete: Restrict)
  result              MatchResult?
  resultDetail        MatchResultDetail?
  bubblesEvents       BubblesEvent[]
  bubblesLandmarks    BubblesLandmark[]
  bubblesWorldRows    BubblesWorld[]
  bestbeatEvents      BestbeatEvent[]
  bestbeatLandmarks   BestbeatLandmark[]
  bestbeatWorldRows   BestbeatWorld[]
  trunktiltWorldRows  TrunktiltWorld[]
  trunktiltPoseRows   TrunktiltPose[]
  trunktiltEvents     TrunktiltEvent[]
  levelConfigSnapshot Json     @map("level_config_snapshot")
  startedAt           DateTime @default(now())

  @@index([sessionId])
  @@index([gameId])
  @@index([levelId])
  @@map("matches")
}

model MatchResult {
  id         String   @id @default(uuid())
  matchId    String   @unique
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  score      Int
  durationMs Int      @map("duration_ms")
  completed  Boolean
  createdAt  DateTime @default(now())

  @@map("match_results")
}

model MatchResultDetail {
  id        String   @id @default(uuid())
  matchId   String   @unique
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  data      Json
  createdAt DateTime @default(now())

  @@map("match_result_details")
}

model BubblesEvent {
  id        String   @id @default(uuid())
  matchId   String   @map("match_id")
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type      String
  timestamp BigInt
  data      Json
  createdAt DateTime @default(now())

  @@index([matchId, timestamp])
  @@map("bubbles_events")
}

model BubblesLandmark {
  id        String   @id @default(uuid())
  matchId   String   @map("match_id")
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  timestamp BigInt
  data      Json
  createdAt DateTime @default(now())

  @@index([matchId, timestamp])
  @@map("bubbles_landmarks")
}

model BubblesWorld {
  id        String   @id @default(uuid())
  matchId   String   @map("match_id")
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  timestamp BigInt
  device    String
  data      Json
  createdAt DateTime @default(now())

  @@index([matchId, timestamp])
  @@map("bubbles_world")
}

model BestbeatEvent {
  id        String   @id @default(uuid())
  matchId   String   @map("match_id")
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type      String
  timestamp BigInt
  data      Json
  createdAt DateTime @default(now())

  @@index([matchId, timestamp])
  @@map("bestbeat_events")
}

model BestbeatLandmark {
  id        String   @id @default(uuid())
  matchId   String   @map("match_id")
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  timestamp BigInt
  data      Json
  createdAt DateTime @default(now())

  @@index([matchId, timestamp])
  @@map("bestbeat_landmarks")
}

model BestbeatWorld {
  id        String   @id @default(uuid())
  matchId   String   @map("match_id")
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  timestamp BigInt
  device    String
  data      Json
  createdAt DateTime @default(now())

  @@index([matchId, timestamp])
  @@map("bestbeat_world")
}

model TrunktiltWorld {
  id                  String   @id @default(uuid())
  matchId             String   @map("match_id")
  match               Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  timestampMs         BigInt   @map("timestamp_ms")
  frameId             Int      @map("frame_id")
  ballPosX            Float    @map("ball_pos_x")
  ballPosY            Float    @map("ball_pos_y")
  ballPosZ            Float    @map("ball_pos_z")
  ballVelX            Float    @map("ball_vel_x")
  ballVelY            Float    @map("ball_vel_y")
  ballVelZ            Float    @map("ball_vel_z")
  velocityMag         Float    @map("velocity_mag")
  accelMag            Float    @map("accel_mag")
  tiltXX              Float    @map("tilt_x_x")
  tiltXY              Float    @map("tilt_x_y")
  tiltXZ              Float    @map("tilt_x_z")
  tiltZX              Float    @map("tilt_z_x")
  tiltZY              Float    @map("tilt_z_y")
  tiltZZ              Float    @map("tilt_z_z")
  inputVirtX          Float    @map("input_virt_x")
  inputVirtZ          Float    @map("input_virt_z")
  createdAt           DateTime @default(now())

  @@unique([matchId, frameId])
  @@index([matchId, timestampMs])
  @@map("trunktilt_world")
}

model TrunktiltPose {
  id           String   @id @default(uuid())
  matchId      String   @map("match_id")
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  timestampMs  BigInt   @map("timestamp_ms")
  frameId      Int      @map("frame_id")
  landmarkId   Int      @map("landmark_id")
  x            Float
  y            Float
  z            Float
  visibility   Float?
  createdAt    DateTime @default(now())

  @@unique([matchId, frameId, landmarkId])
  @@index([matchId, landmarkId, timestampMs])
  @@index([matchId, frameId])
  @@map("trunktilt_pose")
}

model TrunktiltEvent {
  id        String   @id @default(uuid())
  matchId   String   @map("match_id")
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type      String
  timestamp BigInt
  data      Json
  createdAt DateTime @default(now())

  @@index([matchId, timestamp])
  @@map("trunktilt_events")
}
